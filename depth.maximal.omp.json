{
	"$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
	"version": 4,
	"final_space": true,
	"blocks": [
		{
			"type": "rprompt",
			"alignment": "right",
			"segments": [
				{
					"type": "git",
					"style": "plain",
					"foreground": "magenta",
					"options": {
						"fetch_status": true,
						"branch_icon": "",
						"branch_identical_icon": "",
						"branch_ahead_icon": "",
						"branch_behind_icon": "",
						"branch_gone_icon": ""
					},
					"template": "{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Added }} <green>ADD</>{{end}}{{ if .Working.Deleted}} <red>DEL</>{{ end }} {{ if .Working.Modified }} <yellow>MOD</>{{ end }}{{ if .Working.Untracked }} <yellow>UNT</>{{ end}}{{ if .Working.Unmerged }} <cyan>UNM</>{{ end }} ({{ .HEAD }})"
				}
			]
		},
		{
			"type": "prompt",
			"alignment": "left",
			"segments": [
				{
					"type": "python",
					"style": "plain",
					"foreground": "yellow",
					"template": "{{ if .Venv }}{{ \"{\" }}{{ .Venv }} v{{ .Full }}{{ \"}\" }} {{ end }}"
				},
				{
					"type": "path",
					"style": "plain",
					"foreground": "blue",
					"options": {
						"style": "agnoster"
					},
					"template": "[{{ .Path }}]"
				}
			]
		},
		{
			"type": "prompt",
			"alignment": "left",
			"newline": true,
			"segments": [
				{
					"type": "status",
					"style": "plain",
					"foreground": "green",
					"foreground_templates": [
						"{{ if eq .Code 0 }}green{{else}}red{{ end }}"
					],
					"options": {
						"always_enabled": true
					},
					"template": "{{ .Shell }} {{ if or (eq .Shell \"pwsh\") (eq .Shell \"powershell\") (eq .Shell \"cmd\") }}>{{ else }}${{ end }}"
				}
			]
		}
	]
}
